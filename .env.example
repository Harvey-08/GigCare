# GigCare Environment Configuration
# Copy this to .env and fill in your actual values
# NEVER commit .env to Git — add it to .gitignore

# =====================================================
# DATABASE
# =====================================================
DATABASE_URL=postgresql://gigcare_user:gigcare_pass@localhost:5432/gigcare

# =====================================================
# JWT
# =====================================================
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars_generate_with_node_-e_console.log_require_crypto_randomBytes_64_toString_hex
JWT_EXPIRES_IN=1h

# =====================================================
# EMAIL / SMTP FOR OTP
# =====================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM="GigCare <no-reply@gigcare.app>"

# =====================================================
# RAZORPAY (Test Mode)
# =====================================================
# Get these from: https://dashboard.razorpay.com/ (sign up first)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_dashboard

# =====================================================
# WEATHER APIs (All Free Tier)
# =====================================================
# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_get_free_at_openweathermap.org

# WAQI (Air Quality): https://aqicn.org/api/
WAQI_TOKEN=your_waqi_token_get_free_at_aqicn.org

# Open-Meteo (Rainfall): NO KEY REQUIRED
# Free API at: https://open-meteo.com/

# =====================================================
# ML SERVICES
# =====================================================
ML_PREMIUM_SERVICE_URL=http://localhost:5001
ML_FRAUD_SERVICE_URL=http://localhost:5002

# =====================================================
# INTERNAL AUTH
# =====================================================
# Used for trigger-engine to admin-api communication
INTERNAL_SERVICE_KEY=your_random_internal_key_here_min_32_chars

# =====================================================
# APP CONFIG
# =====================================================
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# =====================================================
# MOCK/DEMO MODE
# =====================================================
# Set to true to use mock data for weather/platform APIs
# Set to false to use real API calls
USE_MOCK_DATA=true